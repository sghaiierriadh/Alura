# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# POC sans UI auth : UUID d’un utilisateur créé dans Supabase → Authentication → Users (avec service role ci-dessus)
# POC_SAVE_AGENT_USER_ID=00000000-0000-0000-0000-000000000000

# Google AI (server only — onboarding PDF analysis)
GEMINI_API_KEY=your-google-ai-api-key
# Optional: default serveur = gemini-1.5-flash (override si besoin)
# GEMINI_MODEL=gemini-1.5-pro
