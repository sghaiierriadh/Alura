# URL publique de l’app Alura (iframe du widget / intégration cross-domain). Dev typique : http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CSP `frame-ancestors` pour `/widget` et `/embed` (défaut : * = tout hôte parent). Ex. : 'self' https://partenaire.example
# WIDGET_CSP_FRAME_ANCESTORS=*

# Supabase (public — safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AI (server only — onboarding PDF analysis)
GEMINI_API_KEY=your-google-ai-api-key
# Optional: default serveur = gemini-1.5-flash (override si besoin)
# GEMINI_MODEL=gemini-1.5-pro
